<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/ivStoreImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/store_1" /> <!-- Ganti dengan ID gambar aslimu -->

    <!-- Overlay Gelap agar teks lebih terbaca (Opsional) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000" />

    <!-- Hidden description (required by StoreAdapter) -->
    <TextView
        android:id="@+id/tvStoreDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Teks Nama Toko (Kotak Merah Besar) -->
    <TextView
        android:id="@+id/tvStoreName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="4dp"
        android:background="@color/secondary"
        android:fontFamily="@font/cinzel_bold"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        tools:text="GRAMEDIA"
        android:textColor="@color/text"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tvPlanAVisit"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Teks Plan a Visit (Kotak Merah Kecil) -->
    <TextView
        android:id="@+id/tvPlanAVisit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@color/secondary"
        android:letterSpacing="0.1"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:text="@string/plan_a_visit"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:fontFamily="@font/source_code_pro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tvStoreName" />

</androidx.constraintlayout.widget.ConstraintLayout>