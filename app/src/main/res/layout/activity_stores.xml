<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_stores.xml - Stores Page Layout

    Menampilkan halaman daftar toko buku dengan fitur:
    - Vertical scrollable RecyclerView untuk store cards
    - Navigation drawer
    - Hamburger menu untuk membuka drawer

    Colors:
    - Background: Primary (#0E0911)
    - Icon accent: Tertiary (#BC8F4B)

    Fonts:
    - Heading: Cinzel Bold (32sp)

    Components:
    - DrawerLayout: Main layout dengan navigation drawer
    - ConstraintLayout: Main content area
    - RecyclerView: Vertical scrollable store list
    - layout_navbar.xml: Navigation drawer
-->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/stores_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.StoresActivity">

    <!-- Main Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/stores_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/primary">

        <!-- Hamburger Menu Icon -->
        <ImageView
            android:id="@+id/btn_open_drawer_stores"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            android:contentDescription="@string/stores_title"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/tertiary" />

        <!-- Stores RecyclerView - Vertical Scrollable -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStores"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="0dp"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_open_drawer_stores"
            tools:listitem="@layout/item_store" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <include
        android:id="@+id/drawer_start_stores"
        layout="@layout/layout_navbar" />

</androidx.drawerlayout.widget.DrawerLayout>
