<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml - Login Page Layout

    Menampilkan halaman login dengan:
    - Background image (background_start_page.png)
    - Logo dan title
    - Form username & password
    - CTA button Log In
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/login_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_start_page"
    tools:context=".activities.LoginActivity">

    <LinearLayout
        android:id="@+id/login_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/login_logo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:contentDescription="@string/start_logo_desc"
            android:src="@drawable/ic_logo" />

        <TextView
            android:id="@+id/login_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/cinzel_bold"
            android:text="@string/start_title"
            android:textAlignment="center"
            android:textColor="@color/text"
            android:textSize="28sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/login_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_login_card"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/login_header">

        <TextView
            android:id="@+id/label_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/source_code_pro_medium"
            android:text="@string/login_username_label"
            android:textColor="@color/text"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/input_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@android:color/transparent"
            android:fontFamily="@font/source_code_pro"
            android:hint="@string/login_username_hint"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/text"
            android:textColorHint="@color/login_hint"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="@color/secondary" />

        <TextView
            android:id="@+id/label_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/source_code_pro_medium"
            android:text="@string/login_password_label"
            android:textColor="@color/text"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/input_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@android:color/transparent"
            android:fontFamily="@font/source_code_pro"
            android:hint="@string/login_password_hint"
            android:inputType="textPassword"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/text"
            android:textColorHint="@color/login_hint"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="@color/secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login_submit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/source_code_pro_medium"
            android:stateListAnimator="@animator/button_press_alpha"
            android:text="@string/log_in"
            android:textAllCaps="true"
            android:textColor="@color/text"
            android:textSize="12sp"
            app:backgroundTint="@color/secondary"
            app:cornerRadius="6dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
